# 项目基础路径
VITE_BASE_URL=/

# 项目标题（显示在浏览器标签页等位置）
VITE_APP_TITLE=博客管理系统

# 项目描述 SoybeanAdmin 是一款清新优雅的管理系统模板
VITE_APP_DESC=SoybeanAdmin is a fresh and elegant admin template

# 图标名称前缀（用于统一图标命名规范）
VITE_ICON_PREFIX=icon

# 本地 SVG 图标组件的前缀，必须包含上方配置的 VITE_ICON_PREFIX
# 格式为 {VITE_ICON_PREFIX}-{本地图标名称}（例如 icon-local-user）
VITE_ICON_LOCAL_PREFIX=icon-local

# 常量路由与权限路由的模式：static（静态，路由在代码中固定定义）｜ dynamic（动态，从后端接口获取）
VITE_AUTH_ROUTE_MODE=dynamic

# 静态权限路由模式下的首页路径（用户登录后默认跳转的页面）
VITE_ROUTE_HOME=/home

# 菜单默认图标（未自定义图标的菜单将使用此图标）
VITE_MENU_ICON=mdi:menu

# 开发模式下是否启用 HTTP 代理（用于解决跨域问题）
VITE_HTTP_PROXY=Y

# vue-router 路由模式：hash（带 # 号的路径）｜ history（正常路径，需服务器配置支持）｜ memory（内存模式，不操作地址栏）
VITE_ROUTER_HISTORY_MODE=history

# 后端服务的请求成功状态码（收到此代码时，判定请求成功）
VITE_SERVICE_SUCCESS_CODE=200

# 后端服务的登出状态码（收到此代码时，用户将被强制登出并跳转至登录页）
# 未登录 无效的身份令牌
VITE_SERVICE_LOGOUT_CODES=401001,401005

# 后端服务的弹窗登出状态码（收到此代码时，将通过弹窗提示并执行登出）
# 如: 账号被封禁 账号被异地登录
# VITE_SERVICE_MODAL_LOGOUT_CODES=

# 后端服务的 Token 过期状态码（收到此代码时，将自动刷新 Token 并重新发送请求）
# 登录凭证过期
VITE_SERVICE_EXPIRED_TOKEN_CODES=401003

# 静态路由模式下，定义的超级管理员角色（拥有所有权限）
VITE_STATIC_SUPER_ROLE=R_SUPER

# 是否生成 SourceMap 文件（N 为不生成，可减小打包体积；Y 为生成，便于开发调试）
VITE_SOURCE_MAP=N

# 用于区分不同域名下的本地存储（避免不同项目的 localStorage/sessionStorage 数据冲突）
VITE_STORAGE_PREFIX=SOY-REACT_

# 控制程序是否自动检测更新（Y 为启用自动检测，N 为关闭）
VITE_AUTOMATICALLY_DETECT_UPDATE=Y

# 后端服务基础地址（测试环境）
VITE_SERVICE_BASE_URL=https://mock.apifox.cn/m1/3109515-0-default

# 其他后端服务基础地址（测试环境，支持配置多个服务，此处以 demo 服务为例）
VITE_OTHER_SERVICE_BASE_URL= `{
  "demo": "http://localhost:9528"
}`

# 是否在终端中显示代理地址日志（Y 为显示，便于开发时确认代理是否生效）
VITE_PROXY_LOG=Y
